# ============================================================
# LinhaMap — Backend FastAPI | variáveis de ambiente (Seção 15)
# Copie para `backend/.env` e preencha. O backend roda SEM nenhuma
# dessas chaves quando ENABLE_MOCK_DATA=true (modo demonstração).
# ============================================================

# ----- Supabase / Banco de dados -----
SUPABASE_URL=
SUPABASE_KEY=
DATABASE_URL=

# ----- Dados públicos -----
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast

# ----- IA (opcional — há fallback por regras) -----
ANTHROPIC_API_KEY=
ENABLE_AI_CLASSIFICATION=false

# ----- Flags do MVP -----
# true  = API usa dados mockados em memória (não precisa de Supabase)
# false = API persiste/consulta no Supabase (exige SUPABASE_URL e SUPABASE_KEY)
ENABLE_MOCK_DATA=true

# ----- CORS (origens permitidas; use vírgula p/ múltiplas, ou * em dev) -----
CORS_ORIGINS=*
