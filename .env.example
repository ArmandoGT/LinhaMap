# ============================================================
# LinhaMap — Exemplo de variáveis de ambiente (Seção 15)
# Copie este arquivo para `.env` (backend) e `.env.local` (frontend)
# e preencha com os valores reais. NUNCA versione o .env preenchido.
# ============================================================

# ----- Supabase / Banco de dados -----
SUPABASE_URL=
SUPABASE_KEY=
DATABASE_URL=

# ----- Integrações de dados públicos -----
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast

# ----- IA (opcional — o sistema funciona sem chave, via fallback) -----
ANTHROPIC_API_KEY=
ENABLE_AI_CLASSIFICATION=false

# ----- Flags do MVP -----
ENABLE_MOCK_DATA=true

# ----- Frontend (Next.js) — usar prefixo NEXT_PUBLIC_ para expor ao browser -----
# A URL pública da API FastAPI que o frontend irá consumir.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
